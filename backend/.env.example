# Copy to .env and fill in. .env is gitignored.

# --- Infrastructure ---------------------------------------------------------
# Async drivers required: postgresql+asyncpg for the DB.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_agent
REDIS_URL=redis://localhost:6379/0

# --- LLM --------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Model the agent reasons with. Opus 4.8 is the most capable; override if needed.
AGENT_MODEL=claude-opus-4-8

# --- Embeddings -------------------------------------------------------------
# Only the deterministic "stub" provider exists in Phase 0; real providers land in Phase 2.
EMBEDDINGS_PROVIDER=stub
EMBEDDING_DIM=1024

# --- External source APIs (optional in Phase 0; adapters land in Phase 2) ----
OPENALEX_MAILTO=
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=

# --- API --------------------------------------------------------------------
# Comma-separated origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
